# Public Supabase configuration used by the storefront and Auth session.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# New Supabase projects may use a publishable key instead of the legacy anon key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server only. Never prefix this value with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
