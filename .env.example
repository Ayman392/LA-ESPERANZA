# Public Supabase configuration used by the storefront and Auth session.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# New Supabase projects may use a publishable key instead of the legacy anon key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server only. Never prefix this value with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Public production URL used for canonical links, sitemap, and structured data.
NEXT_PUBLIC_SITE_URL=https://laesperanza.com.bd

# Optional marketing analytics. Scripts load only after customer consent.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=
